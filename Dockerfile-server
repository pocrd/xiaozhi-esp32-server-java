    #    echo ">>> 下载 TTS 模型 (${TTS_MODEL}) ..." && \
    #    case "$TTS_MODEL" in \
    #        matcha-icefall-zh-en) \
    #            http_proxy="${DOWNLOAD_PROXY}" https_proxy="${DOWNLOAD_PROXY}" \
    #                bash scripts/download_tts.sh matcha ;; \
    #        *) \
    #            http_proxy="${DOWNLOAD_PROXY}" https_proxy="${DOWNLOAD_PROXY}" \
    #                bash scripts/download_tts.sh vits-melo ;; \
    #    esac; \
