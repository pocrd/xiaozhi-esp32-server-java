    #fi && \
    bash scripts/download_models.sh status

# ============================================================
# 公共运行时基础镜像
# ============================================================
FROM eclipse-temurin:21-jre AS runtime-base

RUN apt-get update && apt-get install -y --no-install-recommends \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libxfixes3 \
    libxtst6 \
    libxrender1 \
    libpulse0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /build/app_version.env /app/
COPY --from=builder /build/models /app/models
COPY --from=builder /build/lib /app/lib
ENV LD_LIBRARY_PATH=/app/lib:$LD_LIBRARY_PATH

# ============================================================
# xiaozhi-server（管理后台 API，端口 8091）
# 构建: docker build --target server ...
# ============================================================
FROM runtime-base AS server

COPY --from=builder /build/xiaozhi-server/target/xiaozhi-server-*.jar /app/

RUN echo '#!/bin/bash\n\
if [ -f /app/app_version.env ]; then\n\
  . /app/app_version.env\n\
fi\n\
echo "Starting xiaozhi-server ${APP_VERSION}"\n\
java -Xms512m -Xmx1024m \\\n\
  -Dsherpa_onnx.native.path=/app/lib \\\n\
  -Djava.library.path=/app/lib \\\n\
  -jar /app/xiaozhi-server-${APP_VERSION}.jar\n\
' > /app/start.sh && chmod +x /app/start.sh

CMD ["/bin/bash", "/app/start.sh"]

# ============================================================
# xiaozhi-dialogue（设备对话服务，端口 8092）
# 构建: docker build --target dialogue ...
# ============================================================
FROM runtime-base AS dialogue

COPY --from=builder /build/xiaozhi-dialogue/target/xiaozhi-dialogue-*-exec.jar /app/

RUN echo '#!/bin/bash\n\
if [ -f /app/app_version.env ]; then\n\
  . /app/app_version.env\n\
fi\n\
echo "Starting xiaozhi-dialogue ${APP_VERSION}"\n\
java -Xms512m -Xmx1024m \\\n\
  -Dsherpa_onnx.native.path=/app/lib \\\n\
  -Djava.library.path=/app/lib \\\n\
  -jar /app/xiaozhi-dialogue-${APP_VERSION}-exec.jar\n\
' > /app/start.sh && chmod +x /app/start.sh

CMD ["/bin/bash", "/app/start.sh"]
