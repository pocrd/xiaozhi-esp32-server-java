# Use Eclipse Temurin for both build and runtime stages
FROM eclipse-temurin:21-jdk AS builder

# 构建参数
# Vosk模型大小: small(~50MB) 或 standard(~1.3GB)
ARG VOSK_MODEL_SIZE=small
# TTS本地模型，默认 vits-melo-tts-zh_en（中英文），设为 none 则不下载
ARG TTS_MODEL=none
# 模型下载代理（仅用于 curl，不影响 apt-get）
ARG DOWNLOAD_PROXY=

# 安装必要的构建工具
RUN apt-get update && apt-get install -y --no-install-recommends \
    maven \
    wget \
    unzip \
    curl \
    lbzip2 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# 复制项目本地仓库（sherpa-onnx 等未发布到 Maven Central 的依赖）
COPY repo/ ./repo/

# 先复制所有 pom.xml 以利用 Docker 缓存（依赖不变时跳过下载）
COPY pom.xml ./
COPY xiaozhi-common/pom.xml  ./xiaozhi-common/
COPY xiaozhi-service/pom.xml ./xiaozhi-service/
COPY xiaozhi-ai/pom.xml      ./xiaozhi-ai/
COPY xiaozhi-dialogue/pom.xml ./xiaozhi-dialogue/
COPY xiaozhi-server/pom.xml  ./xiaozhi-server/

# 预下载依赖（单独一层，源码变更时不重复下载）
RUN mvn -Dmaven.repo.local=/root/.m2/repository dependency:go-offline -DexcludeGroupIds=com.xiaozhi || true

# 复制所有模块源代码
COPY xiaozhi-common/src  ./xiaozhi-common/src
COPY xiaozhi-service/src ./xiaozhi-service/src
COPY xiaozhi-ai/src      ./xiaozhi-ai/src
COPY xiaozhi-dialogue/src ./xiaozhi-dialogue/src
COPY xiaozhi-server/src  ./xiaozhi-server/src

# 构建整个多模块项目
RUN mvn -Dmaven.repo.local=/root/.m2/repository package -DskipTests

# 提取项目版本号（从根 pom 的 xiaozhi-parent）
RUN APP_VERSION=$(mvn -q -Dexec.executable=echo -Dexec.args='${project.version}' --non-recursive exec:exec 2>/dev/null || \
        grep '<version>' pom.xml | head -3 | tail -1 | sed -e 's/.*<version>//' -e 's/<\/version>.*//' -e 's/[[:space:]]//g') && \
    echo "APP_VERSION=${APP_VERSION}" > /build/app_version.env && \
    cat /build/app_version.env

# ============================================================
# 下载模型和原生库
# 脚本会自动跳过已存在的文件，支持 Docker 缓存
# ============================================================
COPY scripts/ ./scripts/

RUN mkdir -p /build/models /build/lib && \
