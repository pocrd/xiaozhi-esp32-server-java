# Use Eclipse Temurin for both build and runtime stages
FROM eclipse-temurin:21-jdk AS builder

# 构建参数
# Vosk模型大小: small(~50MB) 或 standard(~1.3GB)
ARG VOSK_MODEL_SIZE=small
# TTS本地模型，默认 vits-melo-tts-zh_en（中英文），设为 none 则不下载
ARG TTS_MODEL=vits-melo-tts-zh_en

# 安装必要的构建工具
RUN apt-get update && apt-get install -y --no-install-recommends \
    maven \
    wget \
    unzip \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# 先复制 lib 目录（包含 sherpa-onnx jar 包），供 Maven 构建时使用
COPY ./lib/ /build/lib/

# 复制源代码并构建
COPY ./src ./src
COPY ./db ./db
COPY pom.xml ./
RUN mvn -Dmaven.repo.local=/root/.m2/repository package -DskipTests

# 提取项目版本号
RUN APP_VERSION=$(grep -A1 "<artifactId>xiaozhi.server</artifactId>" pom.xml | grep "<version>" | sed -e 's/<version>//' -e 's/<\/version>//' -e 's/[[:space:]]//g') && \
    echo "APP_VERSION=${APP_VERSION}" > /build/app_version.env && \
    cat /build/app_version.env

# ============================================================
# 模型处理：优先使用本地预下载的模型，不存在则在线下载
# 本地模型通过 scripts/download_models.sh 预先下载
# ============================================================

RUN mkdir -p /build/models /build/lib

# 复制整个 models 目录（包含 silero_vad.onnx 和可能预下载的模型）
COPY ./models/ /build/models/

